# FitAI — Environment Variables
# Copy this file to .env or .env.development and fill in your values.

# App environment: development | production | staging
EXPO_PUBLIC_APP_ENV=development

# Groq API key for AI features (chat, nutrition analysis, voice transcription)
EXPO_PUBLIC_GROQ_API_KEY=

# Cloudinary for image uploads
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Supabase (authentication, database, storage)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry crash reporting (optional — leave empty to skip)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog analytics (optional — leave empty to skip)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
