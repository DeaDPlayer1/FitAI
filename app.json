{
  "expo": {
    "name": "FitAI - Pulse AI Coach",
    "slug": "fitai-pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitai",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#FFFFFF",
    "primaryColor": "#8B5CF6",
    "privacy": "hidden",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c7157de4-8747-4319-8cb9-e633cdbcdd35",
      "fallbackToCacheTimeout": 30000,
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitai.pulse",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "FitAI uses your camera for workout form detection and progress photos.",
        "NSMicrophoneUsageDescription": "FitAI uses your microphone for voice food logging.",
        "NSHealthShareUsageDescription": "FitAI syncs your health data to personalize your fitness journey.",
        "NSHealthUpdateUsageDescription": "FitAI logs workouts to Apple Health.",
        "NSPhotoLibraryUsageDescription": "FitAI accesses your photo library for profile photos and meal tracking."
      }
    },
    "android": {
      "package": "com.fitai.pulse",
      "versionCode": 1,
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#8B5CF6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.24",
            "newArchEnabled": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "newArchEnabled": true,
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#8B5CF6"
        }
      ],
      "expo-dev-client",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c7157de4-8747-4319-8cb9-e633cdbcdd35"
      },
      "router": {}
    },
    "owner": "sarthak183"
  }
}
